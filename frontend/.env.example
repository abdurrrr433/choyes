# Copy/paste frontend environment for this Vite app.
# Local dev: copy this file to frontend/.env.local.
# Vercel: add these same VITE_* variables in Project Settings > Environment Variables.
# IMPORTANT: do not add Postgres passwords, service-role keys, JWT secrets,
# SUPABASE_SECRET_KEY, or SUPABASE_SERVICE_ROLE_KEY to frontend/Vite env.

VITE_SUPABASE_PROJECT_ID="mziyrhutfmtdczggemhe"
VITE_SUPABASE_URL="https://mziyrhutfmtdczggemhe.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="sb_publishable_BX-kR5ygjqpWDivctSIwXQ_7Pcnne-o"

# Optional fallback only. The app uses VITE_SUPABASE_PUBLISHABLE_KEY first.
# If you prefer the legacy anon JWT instead of the publishable key, set this in Vercel too.
VITE_SUPABASE_ANON_KEY=""
