{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install --include=dev",
  "framework": "vite",
  "env": {
    "VITE_SUPABASE_PROJECT_ID": "mziyrhutfmtdczggemhe",
    "VITE_SUPABASE_URL": "https://mziyrhutfmtdczggemhe.supabase.co",
    "VITE_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_BX-kR5ygjqpWDivctSIwXQ_7Pcnne-o"
  },
  "rewrites": [
    {
      "source": "/((?!assets|favicon\\.ico|favicon\\.png|robots\\.txt|placeholder\\.svg).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
